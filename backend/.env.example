PORT=4000
FRONTEND_URL=http://localhost:5173

# Aiven MySQL connection values
# Easiest option: paste Aiven's Service URI here.
DATABASE_URL=mysql://avnadmin:your-aiven-password@your-aiven-host.aivencloud.com:12345/defaultdb

# Or use separate fields instead.
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your-aiven-password
DB_NAME=defaultdb
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
